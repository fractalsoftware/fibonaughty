/vendor
/node_modules
/public/build
/public/hot
/public/storage

# Laravel Storage & Framework Cache Directories
/storage/app/public/*
!/storage/app/public/.gitignore
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/logs/*
!/storage/logs/.gitignore
/storage/pail
/storage/*.key

# Local SQLite Database Files
/database/*.sqlite
/database/*.sqlite-journal
/database/*.sqlite-shm
/database/*.sqlite-wal

# PHPUnit Configuration & Result Caches
/.phpunit.cache
.phpunit.result.cache

# Environment Configurations (Ignore all local overrides, preserve example)
.env
.env.*
!.env.example
Homestead.json
Homestead.yaml

# Security Certificates, Private Keys & Auth Configuration
*.pem
*.crt
*.key
/auth.json

# Package Manager Logs
npm-debug.log
yarn-error.log
pnpm-debug.log
lerna-debug.log

# OS Metadata Files (macOS, Windows)
.DS_Store
.AppleDouble
.LSOverride
Icon?
Thumbs.db
ehthumbs.db

